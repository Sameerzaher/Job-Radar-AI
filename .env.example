MONGODB_URI=mongodb://localhost:27017/job-radar-ai

# Optional: require x-api-key or Authorization: Bearer <key> for POST /api/admin/sync
# ADMIN_API_KEY=your-secret-key

# OpenAI (for AI job analysis on job details page)
# OPENAI_API_KEY=sk-...

# Telegram (high-match and application success notifications)
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# Auto-apply safety (applyConfig)
# AUTO_APPLY_ENABLED=true
# AUTO_APPLY_SCORE_THRESHOLD=90
# REVIEW_SCORE_MIN=80
# MAX_APPLICATIONS_PER_RUN=10
# MAX_APPLICATIONS_PER_DAY=20
# REQUIRE_REVIEW_FOR_SOURCES=Workable
# DRY_RUN_DEFAULT=false

# Resume tailoring and cover letter generation
# TAILORING_ENABLED=true
# TAILORING_SCORE_THRESHOLD=75
# REQUIRE_TAILORING_BEFORE_APPLY=false
# DEFAULT_AI_MODEL=gpt-4o-mini

# Careers page URL for Playwright scraper
# SCRAPER_CAREERS_URL=http://localhost:3000/careers-sample.html
